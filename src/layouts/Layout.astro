---
import { footer } from '../data/content';
interface Props {
  title?: string;
}
const { title = 'Jane Smith — Product Manager' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-MH0PM4KEN0"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-MH0PM4KEN0');
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
    <footer class="site-footer">
      <p>{footer.text} <a href={footer.linkHref} target="_blank" rel="noopener noreferrer">{footer.linkLabel}</a>.</p>
    </footer>
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --bg: #ffffff;
    --bg-secondary: #fffef9;
    --surface: #fff2cc;
    --surface-hover: #ffe999;
    --border: rgba(0, 0, 0, 0.08);
    --accent: #5b5bd6;
    --accent-bright: #6366f1;
    --accent-glow: rgba(91, 91, 214, 0.18);
    --text-primary: #0f0e17;
    --text-secondary: #4a4958;
    --text-muted: #9896a8;
    --mono: 'JetBrains Mono', monospace;
    --sans: 'Inter', system-ui, sans-serif;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background-color: var(--bg);
    color: var(--text-primary);
    font-family: var(--sans);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .site-footer {
    border-top: 1px solid var(--border);
    padding: 1.5rem 2rem;
    text-align: center;
    font-size: 0.8125rem;
    font-family: var(--mono);
    color: var(--text-muted);
  }

  .site-footer a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Prose links — any <a> inside body text */
  .prose a,
  .hero-summary a {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: color 0.15s;
  }

  .prose a:hover,
  .hero-summary a:hover {
    color: var(--accent-bright);
  }
</style>
