---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import { site, hero, terminalCard } from '../data/content';

// Parse headline template into segments for highlighted rendering
const headlineParts = hero.headline
  .replace('{name}',  `<split:name>`)
  .replace('{years}', `<split:years>`)
  .replace('{role}',  `<split:role>`)
  .split(/(<split:[^>]+>)/)
  .map(part => {
    if (part === '<split:name>')  return { type: 'name',  text: site.name };
    if (part === '<split:years>') return { type: 'years', text: hero.years };
    if (part === '<split:role>')  return { type: 'role',  text: hero.role };
    return { type: 'text', text: part };
  });
---

<Layout title={site.title}>
  <Navbar />

  <main>
    <!-- Hero -->
    <section class="hero">
      <!-- Subtle grid background -->
      <div class="grid-bg" aria-hidden="true"></div>
      <!-- Glow orb -->
      <div class="glow-orb" aria-hidden="true"></div>

      <div class="hero-inner">
        <div class="badge">
          <span class="badge-dot"></span>
          <span>{hero.badge}</span>
        </div>

        <h1 class="hero-title">
          {headlineParts.map(p => {
            if (p.type === 'name')  return <span class="hl-str">{p.text}</span>;
            if (p.type === 'years') return <span class="hl-num">{p.text}</span>;
            if (p.type === 'role')  return <span class="hl-key">{p.text}</span>;
            return p.text;
          })}
        </h1>

        <p class="hero-summary" set:html={hero.summary} />

        <div class="hero-actions">
          <a href={hero.secondaryCta.href} class="btn-primary">{hero.secondaryCta.label}</a>
          <a href={site.cvHref} target="_blank" rel="noopener noreferrer" class="btn-ghost">My CV</a>
          <a href={site.linkedInHref} target="_blank" rel="noopener noreferrer" class="btn-ghost">LinkedIn</a>
        </div>
      </div>

      <!-- Floating terminal card -->
      <div class="terminal-card" aria-hidden="true">
        <div class="terminal-bar">
          <span class="dot red"></span>
          <span class="dot yellow"></span>
          <span class="dot green"></span>
          <span class="terminal-title">profile.json</span>
        </div>
        <pre class="terminal-body"><code><span class="t-brace">&#123;</span>
  <span class="t-key">"name"</span>: <span class="t-str">"{site.name}"</span>,
  <span class="t-key">"role"</span>: <span class="t-str">"{terminalCard.role}"</span>,
  <span class="t-key">"experience"</span>: <span class="t-str">"{terminalCard.experience}"</span>,
  <span class="t-key">"specialities"</span>: [
    {terminalCard.keySkills.map((f, i) => <><span class="t-str">"{f}"</span>{i < terminalCard.keySkills.length - 1 ? <>,{'\n    '}</> : ''}</>)}
  ],
  <span class="t-key">"available"</span>: <span class="t-bool">{String(terminalCard.available)}</span>
<span class="t-brace">&#125;</span></code></pre>
      </div>
    </section>

  </main>
</Layout>

<style>
  main {
    padding-top: 80px;
  }

  /* ── Hero ── */
  .hero {
    position: relative;
    min-height: calc(100vh - 80px);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 5rem 2rem;
    gap: 4rem;
  }

  /* Grid background */
  .grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,0,0,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,0,0,0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 20%, transparent 100%);
    pointer-events: none;
  }

  /* Glow orb */
  .glow-orb {
    position: absolute;
    top: 10%;
    right: 20%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(255, 242, 204, 0.95) 0%, transparent 70%);
    pointer-events: none;
    filter: blur(40px);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 600px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Badge */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    background: var(--surface);
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 100px;
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-secondary);
    width: fit-content;
  }

  .badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 8px #22c55e;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* Title */
  .hero-title {
    font-size: clamp(1.875rem, 4vw, 3rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.025em;
    color: var(--text-primary);
  }

  /* Highlighted variables in the title */
  .hl-str,
  .hl-num,
  .hl-key {
    color: var(--accent);
  }

  /* Role line */
  .hero-role {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1rem;
    color: var(--text-secondary);
  }

  .mono-tag {
    font-family: var(--mono);
    font-size: 0.8125rem;
    color: var(--accent);
    background: var(--surface);
    padding: 0.125rem 0.5rem;
    border-radius: 4px;
  }

  /* Summary */
  .hero-summary {
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.75;
    max-width: 520px;
  }

  .hero-summary em {
    font-style: normal;
    color: var(--text-primary);
    font-weight: 500;
  }


  /* Stats */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.25rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .stat-num {
    font-size: 1.5rem;
    font-weight: 700;
    font-family: var(--mono);
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: var(--border);
  }

  /* Actions */
  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    background: var(--accent);
    color: #fff;
    font-weight: 600;
    font-size: 0.9375rem;
    border-radius: 10px;
    transition: background 0.15s, box-shadow 0.15s, transform 0.1s;
  }

  .btn-primary:hover {
    background: var(--accent-bright);
    box-shadow: 0 0 28px var(--accent-glow);
    transform: translateY(-2px);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    color: var(--text-secondary);
    font-weight: 500;
    font-size: 0.9375rem;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: transparent;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }

  .btn-ghost:hover {
    color: var(--text-primary);
    border-color: rgba(0, 0, 0, 0.15);
    background: var(--surface);
  }

  /* Terminal card */
  .terminal-card {
    position: relative;
    z-index: 1;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    box-shadow:
      0 24px 64px rgba(0, 0, 0, 0.1),
      0 0 0 1px rgba(91, 91, 214, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.8);
    flex-shrink: 0;
    width: 320px;
    transform: rotate(1.5deg);
    transition: transform 0.3s ease;
  }

  .terminal-card:hover {
    transform: rotate(0deg) translateY(-4px);
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }
  .dot.red    { background: #ff5f57; }
  .dot.yellow { background: #febc2e; }
  .dot.green  { background: #28c840; }

  .terminal-title {
    margin-left: auto;
    font-size: 0.75rem;
    font-family: var(--mono);
    color: var(--text-muted);
  }

  .terminal-body {
    padding: 1.25rem 1.5rem;
    font-family: var(--mono);
    font-size: 0.8125rem;
    line-height: 1.8;
    overflow-x: auto;
  }

  .t-brace { color: var(--text-muted); }
  .t-key   { color: var(--accent); }
  .t-str   { color: #16a34a; }
  .t-bool  { color: #ea580c; }

  /* Placeholder sections */
  .section-placeholder {
    border-top: 1px solid var(--border);
  }

  .placeholder-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 6rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .placeholder-label {
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .placeholder-inner p {
    color: var(--text-muted);
    font-size: 1rem;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .hero {
      flex-direction: column;
      text-align: center;
      align-items: center;
    }

    .badge { align-self: center; }

    .hero-summary { margin: 0 auto; }

    .hero-stats { justify-content: center; }

    .hero-actions { justify-content: center; }

    .terminal-card {
      width: 100%;
      max-width: 360px;
      transform: none;
    }
  }
</style>
